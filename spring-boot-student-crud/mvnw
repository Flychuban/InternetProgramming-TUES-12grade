#!/bin/sh
# Maven Wrapper script
# This script downloads and runs Apache Maven if not already available

set -e

# Determine the project base directory
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR=$(cd "$(dirname "$0")" && pwd)
  export MAVEN_PROJECTBASEDIR
fi

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
MAVEN_HOME="$HOME/.m2/wrapper"

# Read distribution URL from properties
if [ -f "$WRAPPER_PROPERTIES" ]; then
  DIST_URL=$(grep 'distributionUrl' "$WRAPPER_PROPERTIES" | cut -d'=' -f2- | tr -d '[:space:]')
fi

if [ -z "$DIST_URL" ]; then
  DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.zip"
fi

# Extract version from URL
DIST_FILENAME=$(basename "$DIST_URL")
DIST_NAME="${DIST_FILENAME%%-bin.zip}"
MAVEN_INSTALL="$MAVEN_HOME/dists/$DIST_NAME"

# Download and install Maven if needed
if [ ! -d "$MAVEN_INSTALL" ]; then
  echo "Downloading Maven from $DIST_URL"
  mkdir -p "$MAVEN_HOME/dists"
  TMPFILE=$(mktemp /tmp/maven-wrapper.XXXXXX.zip)

  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$TMPFILE" "$DIST_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMPFILE" "$DIST_URL"
  else
    echo "Error: curl or wget is required to download Maven."
    exit 1
  fi

  echo "Installing Maven"
  unzip -q -d "$MAVEN_HOME/dists" "$TMPFILE"
  rm -f "$TMPFILE"
fi

MAVEN_CMD="$MAVEN_INSTALL/bin/mvn"

if [ ! -x "$MAVEN_CMD" ]; then
  chmod +x "$MAVEN_CMD"
fi

# Run Maven
exec "$MAVEN_CMD" \
  -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" \
  "$@"
